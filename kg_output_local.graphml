<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d2" for="edge" attr.name="relation" attr.type="string" />
  <key id="d1" for="edge" attr.name="weight" attr.type="long" />
  <key id="d0" for="node" attr.name="count" attr.type="long" />
  <graph edgedefault="undirected">
    <node id="直接">
      <data key="d0">1</data>
    </node>
    <node id="调用">
      <data key="d0">1</data>
    </node>
    <node id="测试">
      <data key="d0">1</data>
    </node>
    <edge source="直接" target="调用">
      <data key="d1">1</data>
      <data key="d2">cooccurrence</data>
    </edge>
    <edge source="直接" target="测试">
      <data key="d1">1</data>
      <data key="d2">cooccurrence</data>
    </edge>
    <edge source="调用" target="测试">
      <data key="d1">1</data>
      <data key="d2">cooccurrence</data>
    </edge>
  </graph>
</graphml>
